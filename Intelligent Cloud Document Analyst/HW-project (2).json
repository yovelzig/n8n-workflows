    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\nconst markdown = `# Incident Report: ${item.file_name}\n\n**Analyzed at:** ${item.analyzed_at}\n**Severity:** ${item.severity.toUpperCase()}\n**Risk Score:** ${item.risk_score}/100\n**Routing Team:** ${item.routing_team}\n**SLA:** ${item.sla_minutes} minutes\n**Escalation Required:** ${item.requires_escalation ? 'YES' : 'No'}\n\n## Summary\n${item.summary}\n\n## Affected Entities\n- IPs: ${item.affected_entities.ip_addresses.join(', ') || 'none'}\n- Usernames: ${item.affected_entities.usernames.join(', ') || 'none'}\n- Hostnames: ${item.affected_entities.hostnames.join(', ') || 'none'}\n\n## Recommended Action\n${item.recommended_action}\n\n## Original Log\n\\`\\`\\`\n${item.original_log}\n\\`\\`\\`\n`;\n\nreturn [{\n  json: { ...item },\n  binary: {\n    report: {\n      data: Buffer.from(markdown).toString('base64'),\n      mimeType: 'text/markdown',\n      fileName: `${item.file_name.replace('.txt', '')}_report.md`\n    }\n  }\n}];"
      },
