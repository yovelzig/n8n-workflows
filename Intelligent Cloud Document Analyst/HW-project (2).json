    {
      "parameters": {
        "jsCode": "const rawText = $input.first().json.content.parts[0].text;\n\n// Gemini sometimes wraps JSON in ```json ... ``` markdown fences — strip them\nconst cleaned = rawText.replace(/```json\\n?/g, '').replace(/```/g, '').trim();\n\nconst analysis = JSON.parse(cleaned);\n\nreturn [{\n  json: {\n    ...analysis,\n    original_log: $input.first().json.data,\n    file_name: $('Read/Write Files from Disk').first().json.fileName,\n    analyzed_at: new Date().toISOString()\n  }\n}];"
      },
