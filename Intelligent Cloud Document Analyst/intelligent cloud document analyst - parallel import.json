    {
      "parameters": {
        "jsCode": "const items=$input.all();\nfor(const item of items){\n const b=item.binary?.data||{}, j=item.json||{};\n const filename=b.fileName||j.name||j.fileName||j.filename||'unknown_file';\n const mimeType=b.mimeType||j.mimeType||'';\n let ext=(b.fileExtension||j.fileExtension||j.extension||(filename.includes('.')?filename.split('.').pop():'')||'').toLowerCase();\n if(!ext&&mimeType==='application/pdf') ext='pdf';\n if(!ext&&mimeType==='application/vnd.openxmlformats-officedocument.wordprocessingml.document') ext='docx';\n if(!ext&&mimeType==='text/plain') ext='txt';\n item.json={...j,filename,fileName:filename,fileExtension:ext,mimeType,fileSize:b.fileSize||j.size||0,original_drive_file_id:j.id,supported_file:['pdf','docx','txt'].includes(ext)};\n}\nreturn items;"
      },
