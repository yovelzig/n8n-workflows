        "options": {
          "timeout": 120000
        }
      },
      "id": "1fd44e09-878b-4fd2-9f96-ab9b39b350eb",
      "name": "Metadata Enrichment API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        5056,
        752
      ]
    },
    {
      "parameters": {
        "jsCode": "const a=$('Parse Gemini JSON').item.json;\nconst m=$input.first().json;\nconst actions=Array.isArray(a.action_items)?a.action_items.join(', '):String(a.action_items||'');\nreturn [{json:{document_id:m.document_id,filename:a.filename,file_type:a.file_type,processed_at:m.processed_at,classification:a.classification,department:m.department,sentiment:a.sentiment,confidence_score:m.adjusted_confidence_score??a.confidence_score,summary:(a.summary||'').substring(0,500),routing_tag:m.routing_tag,sensitivity:m.sensitivity,action_items:actions,entities:a.entities,extracted_text:a.extracted_text}}];"
      },
