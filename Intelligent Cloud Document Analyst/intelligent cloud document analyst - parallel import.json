    {
      "parameters": {
        "jsCode": "return $input.all().map(item=>{\n const text=item.json.cleaned_text||'';\n item.json.prompt=`You are a business document intelligence assistant.\nReturn ONLY valid JSON with exactly:\n{\n \"summary\":\"2-3 sentence summary\",\n \"classification\":\"one of: [invoice, contract, purchase_order, vendor_agreement, business_report, other]\",\n \"sentiment\":\"one of: [positive, neutral, negative]\",\n \"entities\":{\"people\":[],\"organizations\":[],\"dates\":[],\"amounts\":[]},\n \"action_items\":[],\n \"confidence_score\":0.0\n}\nBusiness document text:\n${text}`;\n return item;\n});"
      },
      "id": "ac8ba334-5dd0-4573-af5a-0f77a6820eee",
      "name": "Build Gemini Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        4336,
        752
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-3.5-flash:generateContent",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": {{ JSON.stringify($json.prompt) }}\n        }\n      ]\n    }\n  ],\n  \"generationConfig\": {\n    \"temperature\": 0.2,\n    \"responseMimeType\": \"application/json\"\n  }\n}",
        "options": {
          "timeout": 120000
        }
      },
      "id": "7b1047ab-62b6-4302-bab4-764827d78e64",
      "name": "Gemini 3 Flash Analysis",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        4576,
        752
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "M32cIQ36LRKKKJOr",
          "name": "Header Auth account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const original=$('Build Gemini Prompt').item.json;\nreturn $input.all().map(item=>{\n let raw=item.json.candidates?.[0]?.content?.parts?.[0]?.text||'{}';\n raw=raw.replace(/```json/gi,'').replace(/```/g,'').trim();\n let p={};\n try{p=JSON.parse(raw);}catch(e){const a=raw.indexOf('{'),b=raw.lastIndexOf('}'); if(a>=0&&b>a) p=JSON.parse(raw.slice(a,b+1)); else throw new Error('Failed to parse Gemini JSON: '+e.message);}\n const classes=['invoice','contract','purchase_order','vendor_agreement','business_report','other'];\n const c=String(p.classification||'other').toLowerCase().replace(/\\s+/g,'_');\n const s=String(p.sentiment||'neutral').toLowerCase();\n item.json={filename:original.filename,file_type:original.file_type,extracted_text:original.extracted_text,original_drive_file_id:original.original_drive_file_id,summary:p.summary||'',classification:classes.includes(c)?c:'other',sentiment:['positive','neutral','negative'].includes(s)?s:'neutral',entities:p.entities||{people:[],organizations:[],dates:[],amounts:[]},action_items:Array.isArray(p.action_items)?p.action_items:[],confidence_score:Number(p.confidence_score||0)};\n return item;\n});"
      },
      "id": "7e874f99-8239-42f2-96f5-d3a7d803d32a",
      "name": "Parse Gemini JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        4816,
        752
      ]
    },
