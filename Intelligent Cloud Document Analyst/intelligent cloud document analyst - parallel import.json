      "parameters": {
        "jsCode": "const meta=$('Normalize File Metadata').item.json;\nreturn $input.all().map(item=>{\n const text=item.json.extracted_text||'';\n item.json={...item.json,cleaned_text:text.replace(/\\s+/g,' ').trim().substring(0,50000),filename:item.json.filename||meta.filename,fileExtension:meta.fileExtension,original_drive_file_id:meta.original_drive_file_id,original_text_length:text.length};\n return item;\n});"
      },
